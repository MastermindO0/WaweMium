-- Config Save/Load
local function SaveConfig()
    pcall(function()
        writefile("WaweMium_Config.json", HttpService:JSONEncode(cfg))
        Notify("Config", "Kaydedildi", 2)
    end)
end

local function LoadConfig()
    pcall(function()
        if isfile("WaweMium_Config.json") then
            for k, v in pairs(HttpService:JSONDecode(readfile("WaweMium_Config.json"))) do
                cfg[k] = v
            end
            Notify("Config", "Yüklendi", 2)
        end
    end)
end

